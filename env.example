# Vite + Supabase (copy to .env.local)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Required for admin login script and Add member API (from Supabase Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: port for create-member API (default 3002)
# CREATE_MEMBER_PORT=3002

# Optional: 4 separate portals, ONE database. In each Vercel project use the SAME
# VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY; set VITE_APP_ROLE different per project:
# VITE_APP_ROLE=admin   (project 1)
# VITE_APP_ROLE=ceo     (project 2)
# VITE_APP_ROLE=leader  (project 3)
# VITE_APP_ROLE=member  (project 4)
